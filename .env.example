# 복사해서 `.env.local` 로 저장해 쓰면 됩니다 (.env.local 은 Git에 안 올라감).
# 줄마다 뜻은 아래 주석 참고.

# Sanity — 원격에 글/미디어 상자 두는 서비스. 아직 미사용이면 빈 칸 두면 됨.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ── 관리자 로그인 (서버만 읽음. NEXT_PUBLIC 붙이면 안 됨) ──
#
# ADMIN_SESSION_SECRET
#   로그인 토큰을 만드는「긴 임의 문자열». 본 서버만 알아야 함.
ADMIN_SESSION_SECRET=
#
# 계정 방법 A — 여러 명: ADMIN_USERS 한 줄 배열 형식(JSON). 실제 값은 로컬에만 두기.
# ADMIN_USERS=[{"username":"직원아이디","password":"직원비번"}]
#
# 계정 방법 B — 한 명만:
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
